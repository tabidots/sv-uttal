---
// src/components/AudioButton.astro
interface Props {
  word: string;
  lang?: string;
}
const { word, lang = "sv-SE" } = Astro.props;
---

<button
  class="audio-btn"
  data-word={word}
  data-lang={lang}
  aria-label={`Play pronunciation of ${word}`}
>
  <img
    class="icon-playing"
    src={`${import.meta.env.BASE_URL}icons/1f50a.svg`}
    alt=""
    width="20"
    height="20"
  />
</button>

<style>
  .audio-btn {
    background: none;
    border: none;
    cursor: pointer;
    position: relative;
    margin: 0;
    padding: 0;
  }
  .audio-btn img {
    width: 1em;
    height: 1em;
    position: relative;
    top: 0.15em;
    display: inline-block;
    background-size: contain;
    background-repeat: no-repeat;
    background-position: 0;
  }
  :global(.starlight-aside) .audio-btn img {
    filter: drop-shadow(0 0 2px rgba(0, 0, 0, 0.4));
  }
  html[data-theme="dark"] .audio-btn img {
    filter: drop-shadow(0 0 1px rgba(255, 255, 255, 0.9));
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>(".audio-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const word = btn.dataset.word!;
      const lang = btn.dataset.lang!;

      const utterance = new SpeechSynthesisUtterance(word);
      utterance.lang = lang;

      utterance.onstart = () => btn.classList.add("playing");
      utterance.onend = () => btn.classList.remove("playing");
      utterance.onerror = () => btn.classList.remove("playing");

      window.speechSynthesis.cancel(); // stop any current speech
      window.speechSynthesis.speak(utterance);
    });
  });
</script>
